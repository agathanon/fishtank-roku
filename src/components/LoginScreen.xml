<?xml version="1.0" encoding="utf-8" ?>
<component name="LoginScreen" extends="Group">
    <interface>
        <field id="loginResult" type="assocarray" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/LoginScreen.brs" />

    <children>
        <!-- Full screen background — Fishtank dusty blue -->
        <Rectangle
            id="bgFull"
            width="1920"
            height="1080"
            color="#4A6878"
        />

        <!-- Subtle texture overlay -->
        <Rectangle
            width="1920"
            height="1080"
            color="#000000"
            opacity="0.15"
        />

        <!-- Login card outer shadow -->
        <Rectangle
            width="520"
            height="640"
            translation="[700, 220]"
            color="#000000"
            opacity="0.4"
        />

        <!-- Login card background -->
        <Rectangle
            id="loginCard"
            width="510"
            height="630"
            translation="[705, 215]"
            color="#3A3632"
        />

        <!-- Card inner area -->
        <Rectangle
            id="loginCardInner"
            width="490"
            height="610"
            translation="[715, 225]"
            color="#44403A"
        />

        <!-- Logo -->
        <Poster
            id="loginLogo"
            uri="pkg:/images/logo.png"
            width="340"
            height="77"
            translation="[790, 250]"
            loadDisplayMode="scaleToFit"
        />

        <!-- Divider — warm tone -->
        <Rectangle
            id="divider1"
            width="410"
            height="2"
            translation="[755, 350]"
            color="#5A5550"
        />

        <!-- Email label -->
        <Label
            id="emailLabel"
            text="Email"
            translation="[760, 372]"
            font="font:SmallBoldSystemFont"
            color="#B8B0A8"
        />

        <!-- Email field focus highlight -->
        <Rectangle
            id="emailFieldFocus"
            width="414"
            height="54"
            translation="[753, 398]"
            color="#CC3333"
            visible="false"
        />

        <!-- Email field background -->
        <Rectangle
            id="emailFieldBgTop"
            width="410"
            height="50"
            translation="[755, 400]"
            color="#6B6560"
        />

        <!-- Email text display -->
        <Label
            id="emailText"
            text=""
            translation="[770, 410]"
            width="380"
            height="30"
            font="font:SmallSystemFont"
            color="#FFFFFF"
        />

        <!-- Password label -->
        <Label
            id="passwordLabel"
            text="Password"
            translation="[760, 468]"
            font="font:SmallBoldSystemFont"
            color="#B8B0A8"
        />

        <!-- Password field focus highlight -->
        <Rectangle
            id="passwordFieldFocus"
            width="414"
            height="54"
            translation="[753, 494]"
            color="#CC3333"
            visible="false"
        />

        <!-- Password field background -->
        <Rectangle
            id="passwordFieldBgTop"
            width="410"
            height="50"
            translation="[755, 496]"
            color="#6B6560"
        />

        <!-- Password text display (masked) -->
        <Label
            id="passwordText"
            text=""
            translation="[770, 506]"
            width="380"
            height="30"
            font="font:SmallSystemFont"
            color="#FFFFFF"
        />

        <!-- Log In button focus highlight -->
        <Rectangle
            id="loginButtonFocus"
            width="414"
            height="59"
            translation="[753, 571]"
            color="#FFFFFF"
            visible="false"
        />

        <!-- Log In button -->
        <Rectangle
            id="loginButtonBgTop"
            width="410"
            height="55"
            translation="[755, 573]"
            color="#CC3333"
        />

        <Label
            id="loginButtonText"
            text="Log In"
            width="410"
            height="55"
            translation="[755, 576]"
            horizAlign="center"
            vertAlign="center"
            font="font:MediumBoldSystemFont"
            color="#FFFFFF"
        />

        <!-- Error message -->
        <Label
            id="errorLabel"
            text=""
            width="410"
            translation="[755, 642]"
            horizAlign="center"
            font="font:SmallSystemFont"
            color="#FF6666"
        />

        <!-- Status message -->
        <Label
            id="statusLabel"
            text=""
            width="410"
            translation="[755, 672]"
            horizAlign="center"
            font="font:SmallestSystemFont"
            color="#999999"
        />

        <!-- Help text at bottom -->
        <Label
            text="Use Up/Down to navigate, OK to select"
            width="1920"
            translation="[0, 780]"
            horizAlign="center"
            font="font:SmallestSystemFont"
            color="#5A7888"
        />
    </children>
</component>
