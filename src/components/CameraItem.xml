<?xml version="1.0" encoding="utf-8" ?>
<component name="CameraItem" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="onContentChanged" />
        <field id="focusPercent" type="float" onChange="onFocusChanged" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/CameraItem.brs" />

    <children>
        <!-- Status dot -->
        <Poster
            id="statusDot"
            width="10"
            height="10"
            translation="[6, 17]"
            uri="pkg:/images/status_dot.png"
            blendColor="#44CC44"
        />

        <!-- Camera name -->
        <Label
            id="nameLabel"
            translation="[24, 6]"
            width="250"
            height="36"
            font="font:SmallSystemFont"
            color="#AAAAAA"
        />

        <!-- Access tier badge -->
        <Label
            id="accessBadge"
            translation="[276, 10]"
            width="50"
            height="24"
            font="font:SmallestSystemFont"
            horizAlign="right"
            color="#666666"
        />
    </children>
</component>
