<?xml version="1.0" encoding="utf-8" ?>
<component name="CameraItem" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="onContentChanged" />
        <field id="focusPercent" type="float" onChange="onFocusChanged" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/CameraItem.brs" />

    <children>
        <!-- Now playing indicator (red bar on left edge) -->
        <Rectangle
            id="playingIndicator"
            width="3"
            height="36"
            translation="[0, 4]"
            color="#CC3333"
            visible="false"
        />

        <!-- Status dot -->
        <Poster
            id="statusDot"
            width="10"
            height="10"
            translation="[10, 17]"
            uri="pkg:/images/status_dot.png"
            blendColor="#44CC44"
        />

        <!-- Camera name -->
        <Label
            id="nameLabel"
            translation="[28, 6]"
            width="290"
            height="36"
            font="font:SmallSystemFont"
            color="#AAAAAA"
        />
    </children>
</component>
